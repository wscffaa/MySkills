# Midscene AI 模型配置
# 复制此文件为 .env 并填写你的配置

# API 端点地址（必需）
MIDSCENE_MODEL_BASE_URL=https://api.openai.com/v1

# API 密钥（必需）
MIDSCENE_MODEL_API_KEY=your-api-key

# 模型名称（必需）
MIDSCENE_MODEL_NAME=gpt-4o

# 模型家族（可选，非 OpenAI 模型需要设置）
# 可选值: gemini | qwen2.5-vl | doubao-vision
# MIDSCENE_MODEL_FAMILY=gemini

# ============ 常用模型配置示例 ============

# --- OpenAI ---
# MIDSCENE_MODEL_BASE_URL=https://api.openai.com/v1
# MIDSCENE_MODEL_API_KEY=sk-xxx
# MIDSCENE_MODEL_NAME=gpt-4o

# --- Gemini ---
# MIDSCENE_MODEL_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# MIDSCENE_MODEL_API_KEY=your-gemini-key
# MIDSCENE_MODEL_NAME=gemini-2.0-flash
# MIDSCENE_MODEL_FAMILY=gemini

# --- 通义千问 (Qwen) ---
# MIDSCENE_MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# MIDSCENE_MODEL_API_KEY=your-qwen-key
# MIDSCENE_MODEL_NAME=qwen-vl-max
# MIDSCENE_MODEL_FAMILY=qwen2.5-vl

# --- 豆包 (Doubao) ---
# MIDSCENE_MODEL_BASE_URL=your-doubao-endpoint
# MIDSCENE_MODEL_API_KEY=your-doubao-key
# MIDSCENE_MODEL_NAME=your-doubao-model
# MIDSCENE_MODEL_FAMILY=doubao-vision
